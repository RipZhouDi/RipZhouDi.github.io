---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projects = [
	{
		title: 'WebGIS 全流程实验台',
		description: '聚焦数据发布、空间查询、符号化表达与多图层联动的完整 WebGIS 实践。',
		href: 'https://negiao-pages.share.connect.posit.cloud/WebGIS/index.html?v=20260405#/register',
		tags: ['OpenLayers', 'GeoJSON', 'Spatial Query'],
	},
	{
		title: '时空数据叙事项目',
		description: '围绕地理现象的时间变化构建可视化叙事，强调交互反馈与地图动效设计。',
		href: '/blog',
		tags: ['Story Map', 'Data Viz', 'Animation'],
	},
	{
		title: 'GIS 算法笔记库',
		description: '整理缓冲区、叠加分析、空间索引等算法实现，配合案例与复杂度分析。',
		href: '/blog',
		tags: ['GIS Algorithm', 'R-Tree', 'Raster/Vector'],
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${SITE_TITLE} | 项目展示`} description="GIS 项目展示与 WebGIS 在线预览" />
	</head>
	<body>
		<Header />
		<main class="projects-page">
			<section class="glass-panel intro-panel">
				<p class="eyebrow">PROJECT SHOWCASE</p>
				<h1>项目展示</h1>
				<p>
					这里收录了我在 GIS 与 WebGIS 方向的实践项目。卡片悬停会触发发光描边，模拟科技仪表盘式交互反馈。
				</p>
			</section>

			<section class="projects-grid">
				{
					projects.map((project) => (
						<a class="glow-card" href={project.href} target={project.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
							<h2>{project.title}</h2>
							<p>{project.description}</p>
							<ul>
								{project.tags.map((tag) => (
									<li>{tag}</li>
								))}
							</ul>
						</a>
					))
				}
			</section>

			<section class="glass-panel embed-panel">
				<h2>WebGIS 页面嵌入预览</h2>
				<p>内嵌地址：negiao-pages.share.connect.posit.cloud/WebGIS</p>
				<div class="embed-wrap">
					<iframe
						src="https://negiao-pages.share.connect.posit.cloud/WebGIS/index.html?v=20260405#/register"
						title="WebGIS Embedded Demo"
						loading="lazy"
						referrerpolicy="strict-origin-when-cross-origin"
					></iframe>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.projects-page {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.intro-panel {
		padding: 1.4rem;
	}

	.eyebrow {
		margin: 0 0 0.35rem;
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		color: var(--text-soft);
	}

	.intro-panel h1 {
		margin: 0 0 0.4rem;
	}

	.intro-panel p {
		margin: 0;
	}

	.projects-grid {
		display: grid;
		gap: 0.9rem;
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.glow-card {
		display: block;
		text-decoration: none;
		padding: 1.1rem;
		border-radius: 1rem;
		border: 1px solid var(--line);
		background: color-mix(in srgb, var(--bg-card) 74%, transparent);
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease;
	}

	.glow-card:hover {
		transform: translateY(-4px);
		border-color: var(--line-strong);
		box-shadow:
			0 0 0 1px rgba(var(--accent-rgb), 0.38),
			0 0 28px rgba(var(--accent-rgb), 0.28),
			0 18px 36px rgba(var(--accent-rgb), 0.16);
	}

	.glow-card h2 {
		margin: 0 0 0.45rem;
		font-size: 1.2rem;
		color: var(--text);
	}

	.glow-card p {
		margin: 0 0 0.8rem;
		font-size: 0.92rem;
	}

	.glow-card ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.glow-card li {
		padding: 0.26rem 0.5rem;
		border-radius: 0.55rem;
		font-size: 0.78rem;
		color: var(--text-soft);
		border: 1px solid var(--line);
		background: color-mix(in srgb, var(--bg-elevated) 75%, transparent);
	}

	.embed-panel {
		padding: 1rem;
	}

	.embed-panel h2 {
		margin: 0 0 0.4rem;
		font-size: 1.3rem;
	}

	.embed-panel p {
		margin: 0 0 0.8rem;
		font-size: 0.9rem;
	}

	.embed-wrap {
		overflow: hidden;
		border-radius: 0.9rem;
		border: 1px solid var(--line);
		background: color-mix(in srgb, var(--bg-card) 72%, transparent);
	}

	.embed-wrap iframe {
		display: block;
		width: 100%;
		height: min(72vh, 720px);
		border: 0;
	}

	@media (max-width: 980px) {
		.projects-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}

		.intro-panel,
		.embed-panel {
			padding: 0.95rem;
		}

		.embed-wrap iframe {
			height: min(65vh, 560px);
		}
	}
</style>
