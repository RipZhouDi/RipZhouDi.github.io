---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import WireframeGlobe from '../components/WireframeGlobe.tsx';
---
<!doctype html>
<html lang="en" class="dark scroll-smooth">
<head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body class="bg-[#0a0a0a] text-neutral-200 antialiased font-sans min-h-screen flex flex-col relative overflow-x-hidden selection:bg-neutral-800 selection:text-white">
    <!-- View Transitions enabled in BaseHead preferably, but we assume it's there -->
    
    <!-- Motion Blur Grid Background -->
    <div class="fixed inset-0 z-[-1] pointer-events-none transition-opacity duration-1000" id="bg-grid" style="background-image: radial-gradient(circle at 1px 1px, #262626 1px, transparent 0); background-size: 40px 40px; mask-image: linear-gradient(to bottom, black 5%, transparent 80%);"></div>

    <Header />
    
    <main class="flex-grow w-full max-w-5xl mx-auto px-4 pt-32 pb-16 z-10 flex flex-col gap-24">
        
        {/* Asymmetric Hero section */}
        <section class="relative w-full flex flex-col md:flex-row items-start justify-between min-h-[50vh] mt-10">
            <div class="max-w-2xl z-10 pt-10">
                <h1 class="text-6xl md:text-8xl font-bold tracking-tighter mb-6 bg-gradient-to-br from-white to-neutral-600 bg-clip-text text-transparent leading-tight mt-10">
                    Mapping the World.<br/>One Pixel at a Time.
                </h1>
                <p class="text-lg md:text-xl text-neutral-400 mb-10 font-light max-w-lg leading-relaxed">
                    Hi, I'm RipZhouDi. I build high-performance spatial web applications, blending GIS logic with modern design aesthetics.
                </p>
                
                <div class="flex gap-4">
                    <a href="/projects" class="group relative px-6 py-3 rounded-full bg-white text-black font-medium active:scale-95 transition-transform duration-200 flex items-center justify-center shadow-lg shadow-white/5">
                        Explore Sandbox
                        <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </div>
            </div>

            <!-- Wireframe Globe Half-Hidden -->
            <div class="absolute -bottom-32 -right-32 w-[600px] h-[600px] md:w-[800px] md:h-[800px] pointer-events-none opacity-80 mix-blend-screen z-0">
                <WireframeGlobe client:only="react" />
            </div>
        </section>

        {/* Bento Grid section */}
        <section class="w-full flex flex-col gap-8 relative z-10">
            <h2 class="text-2xl font-medium tracking-tight text-white mb-2">GIS Toolkit</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="group relative overflow-hidden rounded-2xl bg-[#111] border border-[#262626] p-8 aspect-square md:aspect-auto hover:-translate-y-1 transition-transform duration-300">
                    <!-- Subtle Ray Light effect -->
                    <div class="absolute -top-24 -left-24 w-48 h-48 bg-white opacity-0 group-hover:opacity-5 blur-[80px] rounded-full transition-opacity duration-700"></div>
                    <div class="relative z-10">
                        <div class="text-neutral-400 mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/></svg></div>
                        <h3 class="text-xl font-medium text-white mb-2">Spatial Analysis</h3>
                        <p class="text-neutral-500 text-sm">Processing terrain and vector data using Python, GDAL, and Geopandas with automated pipelines.</p>
                    </div>
                </div>
                <div class="group relative overflow-hidden rounded-2xl bg-[#111] border border-[#262626] p-8 aspect-square md:aspect-auto md:col-span-2 hover:-translate-y-1 transition-transform duration-300">
                    <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-white opacity-0 group-hover:opacity-5 blur-[100px] rounded-full transition-opacity duration-700"></div>
                    <div class="relative z-10 flex flex-col justify-between h-full">
                        <div class="text-neutral-400 mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
                        <div>
                            <h3 class="text-xl font-medium text-white mb-2">WebGIS Architecture</h3>
                            <p class="text-neutral-500 text-sm max-w-md">Building high-performance interactive 3D environments and dashboards using Cesium, Three.js, and modern React/Astro frameworks, rivaling native UI responsiveness.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Featured Post Card */}
        <section class="w-full flex flex-col gap-6 relative z-10 pb-20">
            <h2 class="text-2xl font-medium tracking-tight text-white mb-2">Featured Writing</h2>
            <a href="/blog/astro从0到1" class="group block relative no-underline">
                <div class="relative p-8 rounded-3xl bg-[#0a0a0a] transition-all duration-500 ease-out hover:-translate-y-2 hover:shadow-[0_20px_40px_-20px_rgba(255,255,255,0.05)] border border-transparent hover:border-[#262626]">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-white opacity-0 group-hover:opacity-[0.03] blur-[60px] rounded-full transition-opacity duration-700"></div>
                    <div class="flex justify-between items-start">
                        <div>
                            <p class="text-xs text-neutral-500 mb-3 tracking-widest uppercase">Dec 15, 2025</p>
                            <h3 class="text-2xl font-semibold text-neutral-100 group-hover:text-white transition-colors">Astro 从0到1构建现代博客</h3>
                            <p class="text-neutral-400 mt-2 max-w-2xl">A complete guide to configuring Astro with Tailwind, React, and robust Markdown pipelines for high-performance portfolios.</p>
                        </div>
                        <div class="text-neutral-600 group-hover:text-white transition-colors transform group-hover:translate-x-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                        </div>
                    </div>
                </div>
            </a>
        </section>
    </main>

    <!-- Fade Grid Script -->
    <script>
        window.addEventListener('scroll', () => {
            const grid = document.getElementById('bg-grid');
            if(grid) {
                const scrollY = window.scrollY;
                grid.style.opacity = Math.max(1 - scrollY / 500, 0).toString();
            }
        });
    </script>
</body>
</html>
