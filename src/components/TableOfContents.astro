---
import type { MarkdownHeading } from 'astro';

interface Props {
	headings?: MarkdownHeading[];
}

const { headings = [] } = Astro.props;
const tocItems = headings.filter((item) => item.depth >= 2 && item.depth <= 3);
---

{
	tocItems.length > 0 && (
		<aside class="toc-card" aria-label="文章目录">
			<p class="toc-title">目录</p>
			<ul>
				{tocItems.map((item) => (
					<li class={`depth-${item.depth}`}>
						<a href={`#${item.slug}`}>{item.text}</a>
					</li>
				))}
			</ul>
		</aside>
	)
}

<style>
	.toc-card {
		padding: 1rem;
		border-radius: 1rem;
		border: 1px solid var(--line);
		background: color-mix(in srgb, var(--bg-card) 75%, transparent);
		box-shadow: 0 8px 18px rgba(var(--accent-rgb), 0.08);
	}

	.toc-title {
		margin: 0 0 0.7rem;
		font-size: 0.92rem;
		letter-spacing: 0.06em;
		font-weight: 700;
		text-transform: uppercase;
		color: var(--text);
	}

	ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.42rem;
	}

	li {
		line-height: 1.35;
	}

	li.depth-3 {
		padding-left: 0.9rem;
	}

	a {
		text-decoration: none;
		color: var(--text-soft);
		font-size: 0.9rem;
	}

	a:hover {
		color: var(--text);
	}
</style>
