---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="nav-shell" aria-label="Main navigation">
		<a class="brand" href="/">
			<span class="brand-dot" aria-hidden="true"></span>
			{SITE_TITLE}
		</a>

		<button class="menu-toggle" id="menu-toggle" type="button" aria-label="打开导航" aria-expanded="false">
			<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
				<path fill="currentColor" d="M4 7h16v2H4V7zm0 8v2h16v-2H4zm0-5h16v2H4v-2z"></path>
			</svg>
		</button>

		<div class="internal-links" id="site-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/projects">项目展示</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>

		<div class="actions">
			<a class="repo-link" href="https://github.com/RipZhouDi" target="_blank" rel="noreferrer">GitHub</a>
			<button class="theme-toggle" id="theme-toggle" type="button" aria-label="切换深浅色模式">
				<span class="theme-icon" aria-hidden="true">☀️</span>
				<span class="theme-label">主题</span>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	(() => {
		const root = document.documentElement;
		const themeToggle = document.getElementById('theme-toggle');
		const icon = themeToggle?.querySelector('.theme-icon');
		const label = themeToggle?.querySelector('.theme-label');
		const menuToggle = document.getElementById('menu-toggle');
		const links = document.getElementById('site-links');
		const THEME_KEY = 'site-theme';

		const updateThemeButton = (theme) => {
			if (icon) icon.textContent = theme === 'dark' ? '☀️' : '🌙';
			if (label) label.textContent = theme === 'dark' ? '浅色' : '深色';
		};

		const activeTheme = root.dataset.theme === 'light' ? 'light' : 'dark';
		updateThemeButton(activeTheme);

		themeToggle?.addEventListener('click', () => {
			const currentTheme = root.dataset.theme === 'light' ? 'light' : 'dark';
			const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
			root.dataset.theme = nextTheme;
			window.localStorage.setItem(THEME_KEY, nextTheme);
			updateThemeButton(nextTheme);
			window.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: nextTheme } }));
		});

		menuToggle?.addEventListener('click', () => {
			if (!links) return;
			const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
			menuToggle.setAttribute('aria-expanded', String(!expanded));
			links.classList.toggle('open', !expanded);
		});

		document.addEventListener('click', (event) => {
			if (!links || !menuToggle) return;
			if (window.innerWidth > 900) return;
			if (!(event.target instanceof Node)) return;
			if (!links.contains(event.target) && !menuToggle.contains(event.target)) {
				links.classList.remove('open');
				menuToggle.setAttribute('aria-expanded', 'false');
			}
		});
	})();
</script>

<style>
	.site-header {
		position: sticky;
		top: 0.8rem;
		z-index: 30;
		padding-inline: 1rem;
	}

	.nav-shell {
		width: min(1120px, 100%);
		margin: 0 auto;
		display: grid;
		grid-template-columns: auto auto 1fr auto;
		align-items: center;
		gap: 0.75rem;
		padding: 0.62rem 0.85rem;
		border-radius: 1rem;
		border: 1px solid var(--line);
		background: color-mix(in srgb, var(--bg-elevated) 76%, transparent);
		backdrop-filter: blur(14px) saturate(145%);
		box-shadow: var(--box-shadow);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.45rem 0.35rem;
		font-size: 1.02rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--text);
		text-decoration: none;
		white-space: nowrap;
	}

	.brand-dot {
		width: 0.62rem;
		height: 0.62rem;
		border-radius: 999px;
		background: var(--accent);
		box-shadow: 0 0 16px rgba(var(--accent-rgb), 0.92);
	}

	.menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 0.7rem;
		border: 1px solid var(--line);
		background: color-mix(in srgb, var(--bg-card) 75%, transparent);
		color: var(--text);
		cursor: pointer;
	}

	.internal-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
	}

	.actions {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.repo-link {
		padding: 0.48rem 0.72rem;
		border-radius: 0.68rem;
		border: 1px solid var(--line);
		text-decoration: none;
		font-size: 0.9rem;
		color: var(--text-soft);
		transition: color 180ms ease, border-color 180ms ease;
	}

	.repo-link:hover {
		color: var(--text);
		border-color: var(--line-strong);
	}

	.theme-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.42rem;
		padding: 0.48rem 0.72rem;
		border-radius: 0.68rem;
		border: 1px solid var(--line);
		background: color-mix(in srgb, var(--bg-card) 76%, transparent);
		color: var(--text);
		font-size: 0.9rem;
		cursor: pointer;
		transition: border-color 180ms ease, transform 180ms ease;
	}

	.theme-toggle:hover {
		border-color: var(--line-strong);
		transform: translateY(-1px);
	}

	@media (max-width: 900px) {
		.nav-shell {
			grid-template-columns: auto 1fr auto auto;
			position: relative;
		}

		.menu-toggle {
			display: inline-flex;
		}

		.internal-links {
			display: none;
			position: absolute;
			top: calc(100% + 0.55rem);
			left: 0;
			right: 0;
			padding: 0.6rem;
			flex-direction: column;
			align-items: stretch;
			gap: 0.25rem;
			border-radius: 0.95rem;
			border: 1px solid var(--line);
			background: color-mix(in srgb, var(--bg-elevated) 88%, transparent);
			backdrop-filter: blur(14px);
			box-shadow: var(--box-shadow);
		}

		.internal-links.open {
			display: flex;
		}

		.repo-link {
			display: none;
		}
	}

	@media (max-width: 560px) {
		.site-header {
			top: 0.45rem;
			padding-inline: 0.5rem;
		}

		.brand {
			font-size: 0.9rem;
		}

		.theme-label {
			display: none;
		}
	}
</style>
